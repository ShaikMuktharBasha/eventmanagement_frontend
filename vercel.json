{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://eventmanagement-backend-two.vercel.app/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://eventmanagement-backend-two.vercel.app/socket.io/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
